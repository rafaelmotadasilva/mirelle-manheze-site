# Copie este arquivo para .env.local e preencha os valores reais
# Nunca comite o .env.local no repositório

# ─── Resend ──────────────────────────────────────────────────────
# Crie sua chave em: https://resend.com
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ─── E-mail de destino dos formulários ───────────────────────────
# ATENÇÃO — limitação do Resend sem domínio verificado:
#   O remetente é fixo em "onboarding@resend.dev".
#   Nesse modo, o Resend só permite enviar para o e-mail
#   cadastrado na sua conta Resend (o e-mail de signup).
#
#   Se CONTACT_EMAIL não for o e-mail da sua conta Resend,
#   o envio vai falhar com erro 403.
#
#   Para enviar para qualquer endereço (ex: contato@mirellemanheze.adv.br),
#   verifique o domínio mirellemanheze.adv.br no painel do Resend e
#   atualize o campo "from" em app/api/contact/route.ts para:
#     'Site Mirelle <no-reply@mirellemanheze.adv.br>'
#
CONTACT_EMAIL=contato@mirellemanheze.adv.br

# ─── WhatsApp ─────────────────────────────────────────────────────
# Código do país + DDD + número, sem espaços ou símbolos
NEXT_PUBLIC_WHATSAPP_NUMBER=5511979881341

# ─── URL pública do site ──────────────────────────────────────────
# Sem barra final
NEXT_PUBLIC_SITE_URL=https://mirellemanheze.adv.br
